{
  "name": "pyvelm-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Tailwind + Flowbite build for pyvelm's bundled HTMX UI",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "vendor": "cp ./node_modules/flowbite/dist/flowbite.min.js ./pyvelm/static/dist/flowbite.min.js",
    "build:editor": "esbuild pyvelm/static/src/mail_editor.js --bundle --format=iife --outfile=pyvelm/static/dist/mail_editor.js --minify",
    "build:code-editor": "esbuild pyvelm/static/src/code_editor.js --bundle --format=iife --outfile=pyvelm/static/dist/code_editor.js --minify",
    "build": "tailwindcss -i ./pyvelm/static/tailwind.css -o ./pyvelm/static/dist/pyvelm.css --minify && npm run vendor && npm run build:editor && npm run build:code-editor",
    "dev": "tailwindcss -i ./pyvelm/static/tailwind.css -o ./pyvelm/static/dist/pyvelm.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.11.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-color": "^3.23.6",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-task-item": "^3.23.6",
    "@tiptap/extension-task-list": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/extension-text-style": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@uiw/codemirror-theme-vscode": "^4.25.10",
    "flowbite": "^3.1.2",
    "js-beautify": "^1.15.4"
  }
}
