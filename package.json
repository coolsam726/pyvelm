{
  "name": "pyvelm-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Tailwind + Flowbite build for pyvelm's bundled HTMX UI",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "vendor": "cp ./node_modules/flowbite/dist/flowbite.min.js ./pyvelm/static/dist/flowbite.min.js",
    "build:editor": "esbuild pyvelm/static/src/mail_editor.js --bundle --format=iife --outfile=pyvelm/static/dist/mail_editor.js --minify",
    "build": "tailwindcss -i ./pyvelm/static/tailwind.css -o ./pyvelm/static/dist/pyvelm.css --minify && npm run vendor && npm run build:editor",
    "dev": "tailwindcss -i ./pyvelm/static/tailwind.css -o ./pyvelm/static/dist/pyvelm.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.14",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/language": "^6.11.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "@tiptap/core": "^2.11.5",
    "@tiptap/extension-link": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "flowbite": "^3.1.2"
  }
}
