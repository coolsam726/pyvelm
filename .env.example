# Copy to `.env` and fill in. Loaded by examples/basic.py via python-dotenv.
# Point this at a throwaway database — the smoke test drops/recreates tables.
PYVELM_DSN=postgresql://user:password@localhost:5432/pyvelm_dev

# docker-compose.yml reads the following for its bundled Postgres
# service. Override before bringing the stack up for anything beyond
# local play — the defaults match a toy stack and grant trivial creds.
POSTGRES_USER=pyvelm
POSTGRES_PASSWORD=pyvelm
POSTGRES_DB=pyvelm
PYVELM_PORT=8000
GUNICORN_WORKERS=1
# Set to the IP / CIDR of your reverse proxy when you have one in
# front. Without this gunicorn ignores X-Forwarded-* headers and the
# /login rate limiter sees the proxy IP instead of the real client.
GUNICORN_FORWARDED_ALLOW_IPS=127.0.0.1
