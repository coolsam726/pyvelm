# Copy to `.env` and fill in. Loaded by examples/basic.py via python-dotenv.
# Point this at a throwaway database — the smoke test drops/recreates tables.

# development | production — controls API docs, cookie Secure flags, log level
PYVELM_ENV=development

# SQLAlchemy URL — PostgreSQL (production) or SQLite (local dev / CI).
# Legacy postgresql://… is normalised to postgresql+psycopg://… automatically.
PYVELM_DSN=postgresql+psycopg://user:password@localhost:5432/pyvelm_dev
# PYVELM_DSN=sqlite:///./var/pyvelm-dev.db

# v1.1+ multi-database routing (Postgres tenants only; see docs/multi-database.md):
# PYVELM_DATABASES=tenant_a=postgresql+psycopg://user:pass@localhost/tenant_a
# PYVELM_DATABASES=[{"key":"tenant_a","dsn":"postgresql+psycopg://…","label":"Tenant A"}]

# Vercel + Supabase (demo deploy — reset DB on each build, not each request):
#   PYVELM_DSN=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
#   PYVELM_MODULE_ROOTS=examples/modules:examples/modules_demo
#   PYVELM_ALLOW_DB_NUKE=1   # only for buildCommand / CI; never on live function env
# Local install: pip install -r requirements.txt   (same as pip install '.[geo]')

# Site entry: public landing at / and post-login home URL.
# PYVELM_HOME_URL=/web/admin
# PYVELM_HOME_URL=/
# PYVELM_HOME_URL=/web/views/feedback_signals/home
# PYVELM_LANDING=1

# Shell navigation — see docs/navigation.md
# apps (default): app rail + top-bar subsections (dropdowns for L3 pages)
# sidebar: full nested tree in the sidebar only
# PYVELM_MENU_LAYOUT=apps
# PYVELM_MENU_LAYOUT=sidebar

# docker-compose.yml reads the following for its bundled Postgres
# service. Override before bringing the stack up for anything beyond
# local play — the defaults match a toy stack and grant trivial creds.
POSTGRES_USER=pyvelm
POSTGRES_PASSWORD=pyvelm
POSTGRES_DB=pyvelm
PYVELM_PORT=8000
GUNICORN_WORKERS=1
# Set to the IP / CIDR of your reverse proxy when you have one in
# front. Without this gunicorn ignores X-Forwarded-* headers and the
# /login rate limiter sees the proxy IP instead of the real client.
GUNICORN_FORWARDED_ALLOW_IPS=127.0.0.1

# Cron runner cadence (seconds between ticks). 60s is a reasonable
# floor; jobs with `interval_type="minutes"` smaller than this will
# fire on the next tick rather than precisely at nextcall.
PYVELM_CRON_INTERVAL=60

# Mail dispatcher.
#
#   console (default) — log to stdout; safe for dev/CI.
#   disabled          — silently mark every outgoing row as `sent`.
#   smtp              — talk to a real SMTP server (set the vars below).
PYVELM_MAIL_BACKEND=console

# Only consulted when PYVELM_MAIL_BACKEND=smtp.
# PYVELM_SMTP_HOST=smtp.example.com
# PYVELM_SMTP_PORT=587
# PYVELM_SMTP_USER=
# PYVELM_SMTP_PASSWORD=
# PYVELM_SMTP_FROM=noreply@example.com
# PYVELM_SMTP_USE_TLS=1

# Optional — feedback_signals demo: LLM analysis (background, after submit).
#
# Provider: ollama (local, open-source) | openrouter (hosted) | none | lexicon
# Auto when unset: OpenRouter if OPENROUTER_API_KEY is set, else Ollama.
# LLM_PROVIDER=ollama
#
# --- Ollama (recommended for local testing) ---
# Install: https://ollama.com — then: ollama pull qwen2.5:3b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_JSON_FORMAT=1
# OLLAMA_TIMEOUT=120
# OLLAMA_DISABLED=1
#
# --- OpenRouter (hosted) ---
# OPENROUTER_API_KEY=sk-or-v1-...
#
# Model slug from https://openrouter.ai/collections/free-models
# (Retired IDs like google/gemma-2-9b-it:free return 404 — pick a current :free slug.)
# OPENROUTER_MODEL=openrouter/free
# OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
# OPENROUTER_MODEL=google/gemma-4-31b-it:free
# OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
#
# Few-shot: inject up to N human-verified examples into each LLM prompt (0 = off).
# FEEDBACK_SIGNALS_FEW_SHOT=3
#
# LLM analysis runs in a background thread after submit (lexicon is instant).
# After any OpenRouter error, skip API calls for this many seconds (doubles on repeats).
# OPENROUTER_BACKOFF_SECONDS=90
# OPENROUTER_BACKOFF_MAX=600
# OPENROUTER_BACKOFF_429=120
# OPENROUTER_BACKOFF_404=300
#
# Set OPENROUTER_JSON_MODE=1 if your model supports response_format json_object.
# OPENROUTER_HTTP_REFERER=http://localhost:8000
# OPENROUTER_APP_TITLE=pyvelm feedback demo
