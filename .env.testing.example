# Copy to `.env.testing` for pytest / integration tests (Laravel-style).
# Loaded automatically by pytest and `pyvelm test` — overrides `.env` for tests.
#
# Use a separate throwaway database so tests never touch PYVELM_DSN (dev/prod).

PYVELM_DSN_TEST=postgresql+psycopg://user:password@localhost:5432/pyvelm_test
# PYVELM_DSN_TEST=sqlite:////tmp/pyvelm-test.db

# Postgres: create the database once, e.g.
#   createdb pyvelm_test
# Then migrate the test schema:
#   PYVELM_DSN=$PYVELM_DSN_TEST pyvelm migrate
